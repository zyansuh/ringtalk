{
  "name": "ringtalk",
  "version": "0.1.0",
  "private": true,
  "description": "링톡 - 카카오톡 대항 메신저",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "server": "turbo run dev --filter=@ringtalk/server",
    "app": "cd app && flutter run",
    "app:android:clean": "cd app/android && ./gradlew clean",
    "app:android:build": "cd app/android && ./gradlew build",
    "app:android:assembleDebug": "cd app/android && ./gradlew assembleDebug"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
